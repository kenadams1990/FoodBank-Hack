{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/product/**",
              "ui_kits/hub/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentActivityFeed'] > JSXAttribute > JSXIdentifier[name!=/^(?:entries|status|style|key|ref|className|style|children)$/]",
        "message": "<AgentActivityFeed> doesn't accept that prop. Declared props: entries, status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ApprovalActions'] > JSXAttribute > JSXIdentifier[name!=/^(?:reason|approveLabel|rejectLabel|state|onApprove|onReject|style|key|ref|className|style|children)$/]",
        "message": "<ApprovalActions> doesn't accept that prop. Declared props: reason, approveLabel, rejectLabel, state, onApprove, onReject, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ApprovalActions'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pending|approved|rejected)$/]",
        "message": "<ApprovalActions> state must be one of 'pending' | 'approved' | 'rejected'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: tone, icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|alert|neutral|accent)$/]",
        "message": "<Chip> tone must be one of 'ok' | 'warn' | 'alert' | 'neutral' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DeliveryPlanTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|style|key|ref|className|style|children)$/]",
        "message": "<DeliveryPlanTable> doesn't accept that prop. Declared props: columns, rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExceptionAlert'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|items|style|key|ref|className|style|children)$/]",
        "message": "<ExceptionAlert> doesn't accept that prop. Declared props: title, items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:stages|activeIndex|style|key|ref|className|style|children)$/]",
        "message": "<FlowStrip> doesn't accept that prop. Declared props: stages, activeIndex, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImpactNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|accent|size|style|key|ref|className|style|children)$/]",
        "message": "<ImpactNumber> doesn't accept that prop. Declared props: value, unit, accent, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|style|key|ref|className|style|children)$/]",
        "message": "<Label> doesn't accept that prop. Declared props: children, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|on|size|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, on, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lockup|mark|compact)$/]",
        "message": "<Logo> variant must be one of 'lockup' | 'mark' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Logo> on must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Readout'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Readout> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SurplusCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:species|vessel|lotId|lbs|discountPct|tempC|daysLeft|score|onClick|style|key|ref|className|style|children)$/]",
        "message": "<SurplusCard> doesn't accept that prop. Declared props: species, vessel, lotId, lbs, discountPct, tempC, daysLeft, score, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
