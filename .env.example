# TideLift — Environment Variables
# Copy to .env and fill in values before running.

# App
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL — used in future Prisma migration)
DATABASE_URL=postgresql://tidelift:tidelift@localhost:5432/tidelift

# Auth (optional — add your own auth provider)
SESSION_SECRET=change-me-in-production

# Demo mode (set to 'true' to use in-memory mock store instead of DB)
DEMO_MODE=true
