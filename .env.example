# TideLift — Environment Variables
# Copy to .env and fill in real values

# App
PUBLIC_APP_URL=http://localhost:5173
NODE_ENV=development

# Database (optional — in-memory store used by default in demo mode)
# DATABASE_URL=postgresql://tidelift:password@localhost:5432/tidelift_db

# Auth (optional — stub operator auth used in demo mode)
# JWT_SECRET=your-super-secret-key
# OPERATOR_API_KEY=your-operator-api-key

# Demo mode — set to true to auto-reset DB to seed state on startup
DEMO_MODE=true

# Vision inference service (apps/agents/vision.ts) — base URL of the YOLO
# detection service (services/vision/app.py). Defaults to this when unset. If
# the service is unreachable, intake falls back to the seed CV estimate.
VISION_SERVICE_URL=http://localhost:8000
